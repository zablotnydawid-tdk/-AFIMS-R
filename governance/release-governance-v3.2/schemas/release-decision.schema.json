{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/release-decision.schema.json",
  "title": "AFIMS Release Decision v3.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_status",
    "record_id",
    "generated_at",
    "subject",
    "release_gates",
    "evidence_graph",
    "integrity"
  ],
  "properties": {
    "schema_version": {
      "const": "3.2"
    },
    "record_status": {
      "enum": [
        "PIPELINE_INPUT",
        "CERTIFIED_RECORD",
        "UNVERIFIED_EXAMPLE"
      ]
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit_sha",
        "image"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "commit_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reference",
            "digest"
          ],
          "properties": {
            "reference": {
              "type": "string",
              "minLength": 1
            },
            "digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        }
      }
    },
    "release_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "mandatory",
          "severity",
          "status",
          "evidence_ref"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "mandatory": {
            "type": "boolean"
          },
          "severity": {
            "enum": [
              "INFO",
              "MINOR",
              "MAJOR",
              "CRITICAL"
            ]
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "NOT_EVALUATED"
            ]
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "operational_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "mandatory_for_l4",
          "status",
          "release_digest",
          "environment",
          "issued_at",
          "valid_until",
          "verification"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "mandatory_for_l4": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "VERIFIED",
              "FAILED",
              "MISSING"
            ]
          },
          "release_digest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "environment": {
            "type": "string",
            "minLength": 1
          },
          "issued_at": {
            "type": "string",
            "format": "date-time"
          },
          "valid_until": {
            "type": "string",
            "format": "date-time"
          },
          "verification": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "mechanism",
              "verified"
            ],
            "properties": {
              "mechanism": {
                "type": "string",
                "minLength": 1
              },
              "verified": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "evidence_graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "type"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "from",
              "to"
            ],
            "additionalProperties": false,
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signed",
        "signature_verified"
      ],
      "properties": {
        "signed": {
          "type": "boolean"
        },
        "signature_verified": {
          "type": "boolean"
        },
        "document_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "claimed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "type": "number"
        },
        "maturity_level": {
          "type": "string"
        },
        "decision_status": {
          "type": "string"
        }
      }
    },
    "archive_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prefix",
        "manifest_sha256",
        "objects",
        "versioning_enabled",
        "object_lock_enabled",
        "retention_mode",
        "readback_verified"
      ],
      "properties": {
        "prefix": {
          "type": "string",
          "minLength": 1
        },
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "objects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "sha256",
              "retention_verified"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "retention_verified": {
                "type": "boolean"
              }
            }
          }
        },
        "versioning_enabled": {
          "type": "boolean"
        },
        "object_lock_enabled": {
          "type": "boolean"
        },
        "retention_mode": {
          "enum": [
            "COMPLIANCE"
          ]
        },
        "readback_verified": {
          "type": "boolean"
        }
      }
    }
  }
}
