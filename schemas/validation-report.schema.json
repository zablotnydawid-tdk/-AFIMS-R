{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/afims-r/validation-report.schema.json",
  "title": "AFIMS-R Validation Report",
  "type": "object",
  "required": [
    "schema_version",
    "afims_r_version",
    "contract_hash",
    "source_hash",
    "response_hash",
    "validator_results",
    "metrics",
    "certification",
    "report_hash",
    "sealed"
  ],
  "properties": {
    "schema_version": {
      "const": "AFIMS-R.ValidationRun.v1"
    },
    "afims_r_version": {
      "type": "string"
    },
    "sealed": {
      "const": true
    },
    "validator_results": {
      "type": "array",
      "minItems": 1
    },
    "metrics": {
      "type": "object"
    },
    "certification": {
      "type": "object"
    },
    "report_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}