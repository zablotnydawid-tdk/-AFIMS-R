{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:afims-r:afims-t-fixture:1",
  "title": "AFIMS-T Executable Fixture",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "test_id",
    "requirement",
    "severity",
    "input",
    "instruction",
    "expected_result",
    "prohibited_result",
    "evaluation_method",
    "executable_evaluator",
    "pass_criteria",
    "fail_criteria",
    "execution_status",
    "execution_timestamp",
    "observed_result",
    "evidence_artifact",
    "evidence_sha256"
  ],
  "properties": {
    "test_id": {
      "type": "string",
      "pattern": "^T(?:[1-9]|10)\\.\\d{2}$"
    },
    "severity": {
      "enum": ["S0", "S1", "S2", "S3", "S4"]
    },
    "input": {"type": "string", "minLength": 1},
    "instruction": {"type": "string", "minLength": 1},
    "expected_result": {"type": "string", "minLength": 1},
    "prohibited_result": {"type": "string", "minLength": 1},
    "evaluation_method": {"type": "string", "minLength": 1},
    "executable_evaluator": {
      "type": "object",
      "required": ["evaluator_id", "checks"],
      "properties": {
        "evaluator_id": {"type": "string", "minLength": 1},
        "checks": {"type": "array", "minItems": 1}
      }
    },
    "expected_validator_decision": {"enum": ["PASS", "FAIL"]},
    "execution_status": {"enum": ["NOT_EXECUTED", "PASS", "FAIL"]},
    "execution_timestamp": {"type": ["string", "null"]},
    "observed_result": {"type": ["object", "null"]},
    "evidence_artifact": {"type": ["string", "null"]},
    "evidence_sha256": {"type": ["string", "null"]}
  }
}

